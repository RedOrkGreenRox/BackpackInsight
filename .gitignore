# --- Python (Backend & Scripts) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
venv/
.venv/

# Если база данных генерируется локально
Backend/DB/*.db
Backend/DB/*.sqlite3

# --- Frontend & Vite ---
# Папка со сборкой — главный источник мусора в Git и предупреждений в консоли
dist/
node_modules/

# Игнорируем скомпилированные CSS и Map файлы, так как работаешь с SCSS
Frontend/Web/static/**/*.css.map

# --- Environment & Secrets ---
.env
.env.local
.env.*.local

# --- Scripts & Docs ---
