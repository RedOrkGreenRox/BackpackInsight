@echo off
:: Устанавливаем кодировку UTF-8, чтобы избежать иероглифов
chcp 65001 > nul

:: Переходим в папку, где лежит сам батник (обработка путей с пробелами)
cd /d "%~dp0"

:: Генерируем дерево. 
:: /f — показывать файлы
:: /a — использовать текстовые символы (+, -, |) вместо ломающих кодировку уголков
tree /f /a > structure.txt

echo Готово! Структура сохранена в structure.txt