{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    /* Добавляем обе библиотеки, чтобы TS знал и про браузер, и про воркер */
    "lib": ["ESNext", "DOM", "DOM.Iterable", "WebWorker"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@roots/*": ["ground/roots/*"],
      "@branches/*": ["ground/branches/*"]
    }
  },
  "include": [
    "ground/**/*.ts",
    "ground/**/*.d.ts",
    "ground/**/*.tsx",
    "ground/**/*.vue",
    "ground/types/global.d.ts",
    "functions/**/*.ts"
  ]
}